# ArrowTrader environment template
# Copy this file to .env and fill in real values.

# -----------------------------------------------------------------------------
# FastAPI listener settings
# -----------------------------------------------------------------------------
# Use 0.0.0.0 to accept inbound requests over your local network / tailscale.
API_HOST=0.0.0.0
API_PORT=8000

# -----------------------------------------------------------------------------
# Public API URL shown in the GUI API URL field at startup
# -----------------------------------------------------------------------------
# Set this to your tailscale URL (including /api/v1) when exposing externally.
# Example: https://your-device-name.tailnet.ts.net/api/v1
TAILSCALE_API_URL=

# -----------------------------------------------------------------------------
# Notes
# -----------------------------------------------------------------------------
# The API order-auth secret is NOT read from .env.
# It is entered in the GUI "Secret" field at runtime.
# Incoming order requests must include that same value in body key:
#   "secret" (or alias "spam-key").

TRADOVATE_USERNAME=YOUR_USERNAME
TRADOVATE_PASSWORD=YOUR_PASSWORD
TRADOVATE_EXECUTABLE=your_tradovate_executable_path