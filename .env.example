# ArrowTrader environment template
# Copy this file to .env and fill in real values.

# -----------------------------------------------------------------------------
# Required for external/ngrok auto-start
# -----------------------------------------------------------------------------
NGROK_AUTHTOKEN=your_ngrok_authtoken_here
NGROK_DOMAIN=your-reserved-subdomain.ngrok-free.app

# -----------------------------------------------------------------------------
# Optional overrides (safe defaults shown)
# -----------------------------------------------------------------------------
# Local public-proxy bind address for ngrok forwarding
NGROK_PROXY_HOST=127.0.0.1
NGROK_PROXY_PORT=8080

# Internal FastAPI listener that main.py starts
API_HOST=127.0.0.1
API_PORT=8000

# Public path scope exposed through the proxy
# Keep this as /api/v1 unless you intentionally change your API prefix.
NGROK_ALLOWED_PREFIX=/api/v1

# -----------------------------------------------------------------------------
# Notes
# -----------------------------------------------------------------------------
# The API order-auth secret is NOT read from .env.
# It is entered in the GUI "Secret" field at runtime.
# Incoming order requests must include that same value in body key:
#   "secret" (or alias "spam-key").
